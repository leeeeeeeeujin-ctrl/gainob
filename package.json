{
  "name": "coin-ai-briefing",
  "version": "0.1.0",
  "description": "Personal dashboard that compares Bithumb prices with a global benchmark and sends context to AI.",
  "main": "src/web-handler.js",
  "scripts": {
    "start": "node src/dev-runner.js",
    "dev": "node --watch src/dev-runner.js",
    "server:dev": "node --watch server/index.js",
    "frontend:dev": "npm --prefix frontend run dev",
    "build:frontend": "npm --prefix frontend ci --include=dev && npm --prefix frontend run build",
    "smoke": "node scripts/smoke-test.js",
    "backtest:v1": "node scripts/backtest-v1.js",
    "feature-lab:v1": "node scripts/feature-lab-v1.js",
    "feature-lab:v2": "node scripts/feature-lab-v2.js",
    "db:init": "node scripts/db-init.js"
  },
  "engines": {
    "node": "22.x"
  },
  "dependencies": {
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "lightweight-charts": "^5.1.0",
    "node-fetch": "^2.6.7",
    "pg": "^8.16.3"
  }
}
