{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build:frontend",
  "functions": {
    "api/index.js": {
      "includeFiles": "frontend/out/**"
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api?endpoint=$1"
    },
    {
      "src": "/(.*)",
      "dest": "/api?endpoint=frontend&path=$1"
    }
  ]
}
